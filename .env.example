# WhatsApp Cloud API (Meta) — gratis, hasta 1000 conversaciones/mes
# Sacalo en https://developers.facebook.com/apps -> tu app -> WhatsApp -> API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=elegi_cualquier_palabra_secreta

# Groq — LLM gratis (rate-limited pero suficiente para probar)
# Sacalo en https://console.groq.com/keys
GROQ_API_KEY=

# Firebase — plan Spark (gratis)
# Sacalo en Firebase Console -> Configuración del proyecto -> Cuentas de servicio -> Generar clave privada
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

PORT=3000
